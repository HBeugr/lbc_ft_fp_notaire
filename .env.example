# ============================================================
# Notaire LBC/FT/FP — Variables d'environnement
# Copier vers .env et renseigner les valeurs avant démarrage
# ============================================================

# --- Application ---
# Environnement d'exécution. LAISSER SUR `production` dans ce fichier :
# `.env` alimente la pile déployée (docker-compose.yml). En `development`,
# SQLAlchemy active l'écho SQL — toutes les requêtes ET LEURS PARAMÈTRES sont
# recopiés dans les journaux, données clients comprises — et `/api/docs` est
# publiquement exposé.
# Le développement local n'a pas besoin d'y toucher : docker-compose.dev.yml
# force APP_ENV=development sur le service `api`.
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=["http://localhost:4000","https://notaire-lbcft.local"]

# --- Base de données (PostgreSQL 16) ---
# ⚠️ PostgreSQL n'a pas de compte « root » distinct : le superutilisateur du
# cluster EST DB_USER (POSTGRES_USER côté conteneur). Il n'y a donc pas de
# variable équivalente à l'ancien MYSQL_ROOT_PASSWORD.
DB_HOST=db
DB_PORT=5432
DB_NAME=notaire_lbcft
DB_USER=notaire_user
DB_PASSWORD=changeme_strong_password

# --- Multi-tenant (isolation par schéma) ---
# `shared`  : annuaire de routage — cabinets, aiguillage email → cabinet,
#             comptes Super-Admin, journal d'exploitation. Aucune donnée métier.
SHARED_SCHEMA=shared
# Préfixe des schémas cabinet : un schéma `tenant_<uuid sans tirets>` par
# cabinet notarial. C'est cette isolation qui permet de sauvegarder, restaurer
# ou auditer un cabinet sans jamais toucher aux autres.
TENANT_SCHEMA_PREFIX=tenant_

# --- Clé maîtresse de chiffrement multi-tenant ---
# Chaîne hexadécimale de 64 caractères (32 octets). À générer une seule fois :
#     openssl rand -hex 32
#
# 🔴🔴 AVERTISSEMENT CRITIQUE — NE JAMAIS RÉGÉNÉRER EN PRODUCTION 🔴🔴
#
# Chaque cabinet possède un sel propre (`shared.tenants.key_salt`) ; sa clé AES
# de chiffrement des données est DÉRIVÉE de TENANT_MASTER_KEY + ce sel. La clé
# par cabinet n'est stockée nulle part : elle est recalculée à chaque
# démarrage. Autrement dit, TENANT_MASTER_KEY n'est pas un simple secret
# d'authentification — c'est la racine de confiance de toutes les données
# chiffrées de la plateforme.
#
# Conséquence d'une régénération, d'une perte ou d'une rotation :
#   → les clés dérivées ne correspondent plus,
#   → les données chiffrées de TOUS les cabinets deviennent DÉFINITIVEMENT
#     illisibles (KYC, pièces d'identité, déclarations de soupçon),
#   → aucune restauration de sauvegarde ne les récupère : les sauvegardes
#     contiennent le chiffré, pas la clé.
#
# La destruction de données de conformité constitue une infraction pénale
# (Art. 197). Conserver cette clé dans un coffre-fort de secrets, hors dépôt
# git, avec une copie de secours scellée et hors ligne.
#
# En cas de changement d'hébergement : REPORTER la valeur existante,
# ne pas en générer une nouvelle.
TENANT_MASTER_KEY=

# --- DB DOS (rôle à privilèges restreints — ADR-003, Art. 63) ---
# Rôle PostgreSQL dédié aux déclarations de soupçon : SELECT/INSERT/UPDATE sur
# les DOS, SELECT/INSERT sur leurs addenda, JAMAIS de DELETE. L'append-only
# est ainsi garanti par le SGBD et non par le code applicatif.
# Le rôle est créé vide par infra/postgres/init.sql ; l'API pose son mot de
# passe et ses GRANT par schéma cabinet à chaque démarrage.
DOS_DB_USER=dos_user
DOS_DB_PASSWORD=changeme_dos_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (stockage fichiers chiffré) ---
MINIO_ENDPOINT=storage:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET_DOCUMENTS=notaire-documents
MINIO_USE_SSL=false

# --- Sécurité JWT ---
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# --- Chiffrement AES-256 ---
# Même avertissement que TENANT_MASTER_KEY : changer cette valeur rend les
# données déjà chiffrées illisibles. Générer avec : openssl rand -hex 32
AES_KEY=changeme_aes256_key_32_bytes_hex

# --- 2FA TOTP ---
TOTP_ISSUER=Notaire-LBC-FT-FP
# Obligatoire en production pour notaire_principal et responsable_conformite.
TOTP_REQUIRED=false

# --- Scoring (T2 verrouillé à 15M FCFA dans le code) ---
ESPECES_THRESHOLD_FCFA=15000000

# --- Super-Admin d'exploitation (seed_platform.py) ---
# Compte de la console /super-admin/login. Il vit dans la table `shared.super_admins`,
# hors de tout cabinet : ce n'est PAS un rôle utilisateur et il n'ouvre aucune
# session métier. Créé au premier `make seed`, puis jamais réécrit (idempotent) —
# changer ces valeurs après coup n'a donc aucun effet sur le compte existant.
# OBLIGATOIRE en production : sans ces variables, les défauts du code s'appliquent.
SUPER_ADMIN_EMAIL=superadmin@plateforme.local
SUPER_ADMIN_PASSWORD=changeme_super_admin_password
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# --- Nginx / TLS ---
NGINX_DOMAIN=notaire-lbcft.local

# --- Sauvegardes ---
# Clé de chiffrement des dumps pg_dump. Hexadécimal, 64 caractères EXACTEMENT
# (openssl enc -K attend 32 octets pour AES-256) : openssl rand -hex 32
# Distincte de AES_KEY : compromettre une sauvegarde ne doit pas compromettre
# la base en ligne. À conserver hors du serveur de sauvegarde.
BACKUP_AES_KEY=changeme_backup_aes_key_64_hex_chars
# Rétention des archives, en jours. Sans rapport avec la conservation légale
# de 10 ans (Art. 23), assurée par la base elle-même.
BACKUP_RETENTION_DAYS=30
