# Copie ce fichier en .env.e2e (gitignoré) et renseigne les mots de passe.
# Les 4 premiers comptes sont seedés (backend/seed_admin.py). Les 2 derniers
# (declarant / autre) sont optionnels : renseigne-les seulement si tu as créé ces comptes.

E2E_BASE_URL=http://149.202.59.47:4000

E2E_ADMIN_EMAIL=admin@notaire.local
E2E_ADMIN_PWD=

E2E_NOTAIRE_EMAIL=notaire@notaire.local
E2E_NOTAIRE_PWD=

E2E_RC_EMAIL=conformite@notaire.local
E2E_RC_PWD=

E2E_CLERC_EMAIL=clerc@notaire.local
E2E_CLERC_PWD=

# Optionnels — laisser vide si les comptes n'existent pas (les tests seront "skipped")
E2E_DC_EMAIL=declarant@notaire.local
E2E_DC_PWD=

E2E_AUTRE_EMAIL=autre@notaire.local
E2E_AUTRE_PWD=
